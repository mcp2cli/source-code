---
import '@/styles/globals.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
};

const {
  title = 'mcp2cli — turn any MCP server into a native CLI',
  description = 'mcp2cli discovers any Model Context Protocol server and generates a typed command-line interface from its tools, resources, and prompts.',
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`}
    />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const apply = (mode) => {
          // Keep the `.dark` class for Tailwind's darkMode and the
          // `data-theme` attribute for expressive-code's theme
          // selectors aligned. Both read from the same source of
          // truth (`theme` in localStorage).
          if (mode === 'dark') {
            root.classList.add('dark');
            root.setAttribute('data-theme', 'one-dark-pro');
          } else {
            root.classList.remove('dark');
            root.setAttribute('data-theme', 'one-light');
          }
        };
        try {
          const stored = localStorage.getItem('theme');
          apply(stored === 'light' ? 'light' : 'dark');
        } catch {
          apply('dark');
        }
      })();
    </script>

    {/* Install-command attribution — tags the one-line curl install
        on every page with a per-browser-session visitor UUID so
        downstream CLI runs can be correlated to the web session
        that produced them. Opt-out via DNT or a localStorage flag. */}
    <script is:inline>
      (() => {
        const INSTALL_BASE = 'curl -fsSL https://mcp2cli.dev/install.sh | sh';
        const optedOut =
          (typeof navigator !== 'undefined' && navigator.doNotTrack === '1') ||
          (() => {
            try {
              return localStorage.getItem('mcp2cli_no_track') === '1';
            } catch {
              return false;
            }
          })();
        if (optedOut) return;

        let vid = null;
        try {
          vid = sessionStorage.getItem('mcp2cli_visitor_id');
          if (!vid) {
            vid =
              typeof crypto !== 'undefined' && crypto.randomUUID
                ? crypto.randomUUID()
                : Math.random().toString(36).slice(2) + Date.now().toString(36);
            sessionStorage.setItem('mcp2cli_visitor_id', vid);
          }
        } catch {
          return;
        }
        const tagged = INSTALL_BASE + ' -s -- --ref=' + vid;

        const rewrite = () => {
          // Replace visible text inside every <code> that renders the
          // exact install command. Setting textContent wipes Shiki
          // syntax-highlighting spans — intentional for this single
          // block, and the command is short enough that a uniform
          // foreground reads cleanly.
          document.querySelectorAll('code').forEach((el) => {
            if ((el.textContent || '').trim() === INSTALL_BASE) {
              el.textContent = tagged;
            }
          });
          // And patch expressive-code copy buttons so the clipboard
          // payload matches what users see.
          document.querySelectorAll('button[data-code]').forEach((btn) => {
            if (btn.getAttribute('data-code') === INSTALL_BASE) {
              btn.setAttribute('data-code', tagged);
            }
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', rewrite);
        } else {
          rewrite();
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
