---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}`;

type Direction = 'client‚Üíserver' | 'server‚Üíclient' | 'bidirectional';

type Category = {
  title: string;
  direction: Direction;
  methods: string[];
  doc?: string; // slug under /docs/, without leading slash
};

const categories: Category[] = [
  {
    title: 'Lifecycle',
    direction: 'client‚Üíserver',
    methods: ['initialize', 'notifications/initialized', 'ping'],
    doc: 'protocol-coverage#lifecycle',
  },
  {
    title: 'Discovery',
    direction: 'client‚Üíserver',
    methods: ['tools/list', 'resources/list', 'resources/templates/list', 'prompts/list', '*/list_changed'],
    doc: 'protocol-coverage#discovery',
  },
  {
    title: 'Tools',
    direction: 'client‚Üíserver',
    methods: ['tools/call', '_meta.progressToken', '_meta.task'],
    doc: 'protocol-coverage#tool-invocation',
  },
  {
    title: 'Resources',
    direction: 'bidirectional',
    methods: ['resources/read', 'subscribe', 'unsubscribe', 'resources/updated'],
    doc: 'protocol-coverage#resources',
  },
  {
    title: 'Prompts',
    direction: 'client‚Üíserver',
    methods: ['prompts/get'],
    doc: 'protocol-coverage#prompts',
  },
  {
    title: 'Completions',
    direction: 'client‚Üíserver',
    methods: ['completion/complete', 'ref.context'],
    doc: 'protocol-coverage#completions',
  },
  {
    title: 'Logging',
    direction: 'bidirectional',
    methods: ['logging/setLevel', 'notifications/message'],
    doc: 'protocol-coverage#logging',
  },
  {
    title: 'Progress',
    direction: 'server‚Üíclient',
    methods: ['notifications/progress'],
    doc: 'protocol-coverage#progress',
  },
  {
    title: 'Cancellation',
    direction: 'bidirectional',
    methods: ['notifications/cancelled'],
    doc: 'protocol-coverage#cancellation',
  },
  {
    title: 'Elicitation',
    direction: 'server‚Üíclient',
    methods: ['elicitation/create'],
    doc: 'protocol-coverage#elicitation',
  },
  {
    title: 'Sampling',
    direction: 'server‚Üíclient',
    methods: ['sampling/createMessage'],
    doc: 'protocol-coverage#sampling',
  },
  {
    title: 'Roots',
    direction: 'server‚Üíclient',
    methods: ['roots/list'],
    doc: 'protocol-coverage#roots',
  },
  {
    title: 'Tasks',
    direction: 'client‚Üíserver',
    methods: ['tasks/get', 'tasks/result', 'tasks/cancel'],
    doc: 'protocol-coverage#tasks-long-running-operations',
  },
];

const arrow = (d: Direction) =>
  d === 'client‚Üíserver' ? '‚Üí' : d === 'server‚Üíclient' ? '‚Üê' : '‚Üî';
const directionLabel = (d: Direction) =>
  d === 'client‚Üíserver'
    ? 'client ‚Üí server'
    : d === 'server‚Üíclient'
      ? 'server ‚Üí client'
      : 'bidirectional';
---

<section id="protocol" class="mx-auto max-w-6xl scroll-mt-16 px-4 py-16 sm:px-6">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <div class="mb-2 font-mono text-xs uppercase tracking-wider text-muted-foreground">
        Protocol
      </div>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        Full MCP 2025-11-25 coverage.
      </h2>
      <p class="mt-2 max-w-2xl text-muted-foreground">
        {categories.length} capability groups ‚Äî from lifecycle and discovery
        through bidirectional notifications and long-running tasks ‚Äî each
        mapped to CLI verbs you can invoke today.
      </p>
    </div>
    <a
      href={href('/docs/protocol-coverage')}
      class="hidden whitespace-nowrap text-sm text-muted-foreground underline decoration-muted-foreground underline-offset-4 transition hover:text-foreground hover:decoration-foreground sm:inline-block"
      >Full reference ‚Üí</a
    >
  </div>

  {/* Legend */}
  <div class="mb-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] text-muted-foreground">
    <span class="inline-flex items-center gap-1.5">
      <span class="font-mono text-foreground">‚Üí</span>
      client&nbsp;‚Üí&nbsp;server
    </span>
    <span class="inline-flex items-center gap-1.5">
      <span class="font-mono text-foreground">‚Üê</span>
      server&nbsp;‚Üí&nbsp;client
    </span>
    <span class="inline-flex items-center gap-1.5">
      <span class="font-mono text-foreground">‚Üî</span>
      bidirectional
    </span>
  </div>

  <div
    class="grid gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      categories.map((cat) => {
        const href_ = cat.doc ? `${base}/docs/${cat.doc}` : undefined;
        const Inner = (
          <div class="flex h-full flex-col gap-3 bg-background p-5">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-sm font-semibold tracking-tight">{cat.title}</h3>
              <span
                class="font-mono text-[11px] text-muted-foreground"
                title={directionLabel(cat.direction)}
                aria-label={directionLabel(cat.direction)}
              >
                {arrow(cat.direction)}
              </span>
            </div>
            <ul class="flex flex-wrap gap-1.5">
              {cat.methods.map((m) => (
                <li class="rounded border border-border bg-subtle px-2 py-0.5 font-mono text-[11px] text-muted-foreground">
                  {m}
                </li>
              ))}
            </ul>
          </div>
        );
        return href_ ? (
          <a href={href_} class="group transition hover:bg-muted">
            {Inner}
          </a>
        ) : (
          Inner
        );
      })
    }
  </div>
</section>
