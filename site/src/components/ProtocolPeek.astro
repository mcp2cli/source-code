---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}`;

type Row = { category: string; method: string };

const rows: Row[] = [
  { category: 'Lifecycle', method: 'initialize · initialized · ping' },
  { category: 'Discovery', method: 'tools/list · resources/list · prompts/list · */list_changed' },
  { category: 'Tools', method: 'tools/call + _meta.progressToken + _meta.task' },
  { category: 'Resources', method: 'resources/read · subscribe · unsubscribe · updated' },
  { category: 'Prompts', method: 'prompts/get' },
  { category: 'Completions', method: 'completion/complete · ref.context' },
  { category: 'Logging', method: 'logging/setLevel · notifications/message' },
  { category: 'Progress', method: 'notifications/progress' },
  { category: 'Cancellation', method: 'notifications/cancelled (bidirectional)' },
  { category: 'Elicitation', method: 'elicitation/create  (server → client)' },
  { category: 'Sampling', method: 'sampling/createMessage  (server → client)' },
  { category: 'Roots', method: 'roots/list  (server → client)' },
  { category: 'Tasks', method: 'tasks/get · tasks/result · tasks/cancel' },
];
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <div class="mb-2 font-mono text-xs uppercase tracking-wider text-muted-foreground">
        Protocol
      </div>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        Full MCP 2025-11-25 coverage.
      </h2>
      <p class="mt-2 max-w-2xl text-muted-foreground">
        From lifecycle and discovery through bidirectional notifications and
        long-running tasks — all mapped to CLI verbs.
      </p>
    </div>
    <a
      href={href('/docs/protocol-coverage')}
      class="hidden whitespace-nowrap text-sm text-muted-foreground underline decoration-muted-foreground underline-offset-4 transition hover:text-foreground hover:decoration-foreground sm:inline-block"
      >Full reference →</a
    >
  </div>

  <div class="overflow-hidden rounded-lg border border-border">
    <table class="w-full text-sm">
      <tbody>
        {
          rows.map((row, i) => (
            <tr class:list={['border-border', i !== 0 && 'border-t']}>
              <td class="w-1/3 px-4 py-2.5 font-medium">{row.category}</td>
              <td class="px-4 py-2.5 font-mono text-[13px] text-muted-foreground">
                {row.method}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
