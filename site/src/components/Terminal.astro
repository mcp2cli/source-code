---
import { Code } from 'astro-expressive-code/components';

// The landing-page demo session is rendered through the same <Code>
// component used for every docs code block, so it inherits identical
// framing, padding, font, copy button, theme sync, and titlebar
// styling. The `shellsession` grammar highlights $ prompts, syntax-
// colours the command, and dims the output lines — the visual
// separation we used to paint by hand, now done by the highlighter.

const session = `$ cargo install --path .    # install
   Installed mcp2cli v0.1.0

$ mcp2cli config init --name work \\
    --transport streamable_http \\
    --endpoint http://127.0.0.1:3001/mcp
Config "work" created.

$ mcp2cli link create --name work
Linked: ~/.local/bin/work → mcp2cli

$ work ls    # discover capabilities
tools:     echo  search  email.send  email.reply
resources: file:///{path}  demo://readme
prompts:   summarise  review-diff

$ work email send --to user@example.com --body "Meeting at 3"
✓ queued (delivery_id: a4f2…)`;
---

<Code code={session} lang="shellsession" title="~/projects/work" />
