---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-10 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-3">
      <span>
        Created with <span class="text-[color:#e11d48]" aria-label="love">♥</span> by
        <a
          href="https://tsok.org"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline decoration-muted-foreground underline-offset-4 hover:decoration-foreground"
          >The Source of Knowledge</a
        >.
      </span>
      <span class="hidden sm:inline">·</span>
      <span>Apache License 2.0.</span>
    </div>

    <div class="flex items-center gap-4">
      <a href={`${base}/llms.txt`} class="transition hover:text-foreground">llms.txt</a>
      <span class="hidden sm:inline">© {year}</span>
    </div>
  </div>
</footer>
