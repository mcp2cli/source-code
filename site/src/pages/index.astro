---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Terminal from '@/components/Terminal.astro';
import FeatureGrid from '@/components/FeatureGrid.astro';
import ProtocolPeek from '@/components/ProtocolPeek.astro';
import { Code } from 'astro-expressive-code/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}`;

const oneLinerCmd = `curl -fsSL https://mcp2cli.dev/install.sh | sh`;
const agentPrompt = `Read https://mcp2cli.dev/SKILL.md and set up a cli for my mcp server`;
---

<BaseLayout>
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 -z-10 grid-bg"></div>
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
      <div class="max-w-3xl">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-subtle px-3 py-1 text-xs text-muted-foreground">
          <span class="font-mono text-foreground">$</span>
          <span>mcp2cli 0.1.0 — MCP 2025-11-25</span>
        </div>
        <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl md:text-6xl">
          Turn any MCP server into a native command-line application.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground">
          mcp2cli discovers an MCP server's tools, resources, and prompts, and
          renders them as a typed CLI — required fields become required flags,
          JSON Schema drives argument parsing, dotted names become subcommands.
          One binary. Any server. Real CLI commands.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href={href('/docs/getting-started')}
            class="inline-flex h-10 items-center rounded-md border border-foreground bg-foreground px-5 text-sm font-medium text-background transition hover:bg-foreground/90"
          >
            Get started
          </a>
          <a
            href={href('/docs/protocol-coverage')}
            class="inline-flex h-10 items-center rounded-md px-3 text-sm text-muted-foreground transition hover:text-foreground"
          >
            Protocol coverage
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="flex flex-col items-start gap-5">
        <div class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
          Install
        </div>
        <div class="w-full">
          <Code code={oneLinerCmd} lang="bash" />
        </div>
        <div class="w-full">
          <div class="mb-2 text-xs text-muted-foreground">
            Or install with an <code
              class="rounded border border-border bg-subtle px-1.5 py-0.5 font-mono text-[11px]"
              >AI agent</code
            > — paste this into your assistant:
          </div>
          <Code code={agentPrompt} lang="plaintext" />
        </div>
        <a
          href={href('/docs/files/install')}
          class="text-sm text-muted-foreground underline decoration-muted-foreground underline-offset-4 transition hover:text-foreground hover:decoration-foreground"
          >Full install guide →</a
        >
      </div>
    </div>
  </section>

  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <div class="mb-2 font-mono text-xs uppercase tracking-wider text-muted-foreground">
            Demo
          </div>
          <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
            Any MCP server, one binary away.
          </h2>
        </div>
        <a
          href={href('/docs/getting-started')}
          class="hidden whitespace-nowrap text-sm text-muted-foreground underline decoration-muted-foreground underline-offset-4 transition hover:text-foreground hover:decoration-foreground sm:inline-block"
          >Full walk-through →</a
        >
      </div>
      <Terminal />
    </div>
  </section>

  <section class="border-b border-border bg-subtle/40">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:grid-cols-2 sm:px-6 lg:grid-cols-3">
      <div>
        <div class="mb-3 font-mono text-xs uppercase tracking-wider text-muted-foreground">
          Protocol-first
        </div>
        <p class="text-sm leading-relaxed">
          Full <a
            href={href('/docs/protocol-coverage')}
            class="underline decoration-muted-foreground underline-offset-4 transition hover:decoration-foreground"
            >MCP 2025-11-25</a
          > — discovery, tools, resources, prompts, completions, elicitation,
          sampling, roots, notifications, and tasks. All mapped to CLI verbs.
        </p>
      </div>
      <div>
        <div class="mb-3 font-mono text-xs uppercase tracking-wider text-muted-foreground">
          No code required
        </div>
        <p class="text-sm leading-relaxed">
          Point mcp2cli at an MCP endpoint and start invoking tools. No custom
          client code, no JSON-RPC plumbing, no session boilerplate.
        </p>
      </div>
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="mb-3 font-mono text-xs uppercase tracking-wider text-muted-foreground">
          Shell-native
        </div>
        <p class="text-sm leading-relaxed">
          Exit codes, JSON / NDJSON output, background jobs, Ctrl+C
          cancellation, Unix-socket event streams. Built to pipe.
        </p>
      </div>
    </div>
  </section>

  <FeatureGrid />
  <ProtocolPeek />
</BaseLayout>
